# ============================================================
# CREDENTIALS & SECRETS — never commit these
# ============================================================

# Main config (contains Gemini API key, gateway token, Telegram IDs)
openclaw.json
openclaw.json.bak
openclaw.json.bak.*

# Device identity & private keys
identity/

# WHOOP OAuth tokens
whoop/token.json
whoop/oauth-state.json
whoop/sync.lock

# OpenAI API key, JWT tokens, auth state
agents/main/agent/auth-profiles.json
agents/main/agent/auth-state.json

# Exec approval socket token
exec-approvals.json

# Gateway auth (local token)
gateway/

# ============================================================
# PERSONAL IDENTITY — name, age, height, weight, email
# ============================================================
workspace/USER.md
workspace/health/profile.md
workspace/health/biometrics.md
workspace/health/whoop/profile.json
workspace/health/whoop/body_measurement.json
# Health logs mix in identity details (age, height, weight, health history)
workspace/health/logs/

# ============================================================
# RUNTIME & EPHEMERAL STATE
# ============================================================

# SQLite databases (binary, not useful in git)
memory/main.sqlite
tasks/

# Delivery queue content (failed messages are ephemeral)
delivery-queue/failed/*
!delivery-queue/failed/.gitkeep

# Browser profile data (binary cache, not useful in git)
browser/

# Cron run logs (ephemeral)
cron/runs/

# Device pairing state (contains auth tokens)
devices/paired.json
devices/pending.json

# Command/audit logs (may contain sensitive command history)
logs/commands.log
logs/config-audit.jsonl

# Session history content (conversation history)
agents/main/sessions/*
!agents/main/sessions/.gitkeep

# Update check state
update-check.json

# ============================================================
# MEDIA — personal inbound photos
# ============================================================
media/inbound/

# ============================================================
# OS / EDITOR / IDE
# ============================================================
.DS_Store
Thumbs.db
.idea/
.vscode/
.claude/
*.swp
*.swo

# Compiled bytecode
__pycache__/
*.pyc
*.pyo

# ============================================================
# SECRETS (catch-all patterns)
# ============================================================
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/
.env
.env.*

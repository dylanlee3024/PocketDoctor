# Copy this file to ~/.config/whoop-sync.env and fill in your WHOOP app values.

WHOOP_CLIENT_ID=your_whoop_client_id
WHOOP_CLIENT_SECRET=your_whoop_client_secret
WHOOP_REDIRECT_URI=https://your-domain.example/whoop/callback

# Optional: keep the defaults unless you have a reason to change them.
WHOOP_SCOPES=offline read:profile read:body_measurement read:cycles read:recovery read:sleep read:workout
WHOOP_LOOKBACK_DAYS=21
# WHOOP_TOKEN_PATH=/home/bot0/.openclaw/whoop/token.json
# WHOOP_OUTPUT_DIR=/home/bot0/.openclaw/workspace/health/whoop
